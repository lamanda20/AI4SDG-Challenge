# Environment Variables Template for SportRX AI - ML Module
# Copy to .env and update with actual values

# =========================
# ML Module Configuration
# =========================
ML_MODEL_TYPE=heuristic  # heuristic or xgboost
ML_LOG_LEVEL=INFO
ML_RESPONSE_TIMEOUT=5

# Feature Engineering
ML_FEATURE_SCALING=standardize
ML_MISSING_VALUE_STRATEGY=interpolate

# Risk Thresholds
ML_RISK_WARNING_THRESHOLD=60
ML_RISK_CRITICAL_THRESHOLD=80

# Sentiment Analysis
ML_SENTIMENT_ENABLED=true
ML_DEPRESSION_DETECTION=true
ML_CBT_INTERVENTIONS=true
ML_SENTIMENT_CONFIDENCE_THRESHOLD=0.6

# =========================
# Database Configuration
# =========================
DATABASE_URL=postgresql://user:password@localhost:5432/sportrx_ai
DATABASE_POOL_SIZE=20
DATABASE_ECHO=false

# =========================
# API Configuration
# =========================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_WORKERS=4

# =========================
# External Services
# =========================
# RAG Service
RAG_SERVICE_URL=http://localhost:8001
RAG_TIMEOUT=10

# LLM Service (Groq - free)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# =========================
# Monitoring & Logging
# =========================
LOG_FILE=logs/ml_pipeline.log
SENTRY_DSN=
MONITORING_ENABLED=false

# =========================
# Security
# =========================
JWT_SECRET=your-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# =========================
# Wearables Integration (Future)
# =========================
APPLE_HEALTH_ENABLED=false
GARMIN_ENABLED=false
WHOOP_ENABLED=false

