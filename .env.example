# RAG Environment Configuration Template
# Copy this to .env and fill in your values

# ============= LLM Configuration =============
# OpenAI API Key (required for OpenAI models)
OPENAI_API_KEY=sk-your-key-here

# Anthropic API Key (optional, for Anthropic models)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LLM Provider: 'openai' or 'anthropic'
LLM_PROVIDER=openai

# LLM Model
# OpenAI: 'gpt-4', 'gpt-4-turbo', 'gpt-3.5-turbo'
# Anthropic: 'claude-3-opus', 'claude-3-sonnet', 'claude-3-haiku'
LLM_MODEL=gpt-4

# LLM Temperature (0.0 = deterministic, 1.0 = creative)
# Use 0.2 for medical accuracy
LLM_TEMPERATURE=0.2

# ============= Embedding Configuration =============
# Embedding Provider: 'openai' or 'huggingface'
EMBEDDING_PROVIDER=openai

# Embedding Model
# OpenAI: 'text-embedding-3-small' (1536d), 'text-embedding-3-large' (3072d)
# HuggingFace: 'sentence-transformers/all-MiniLM-L6-v2' (384d)
EMBEDDING_MODEL=text-embedding-3-small

# ============= Vector Database Configuration =============
# Vector Store Type: 'faiss' or 'chroma'
VECTOR_DB_TYPE=faiss

# Vector Store Path (for FAISS and Chroma)
VECTOR_DB_PATH=backend/agents/rag/data/vector_store

# Chroma Collection Name (for Chroma)
CHROMA_COLLECTION_NAME=medical_protocols

# ============= Document Configuration =============
# Base directory for medical documents
MEDICAL_DOCS_PATH=backend/agents/rag/data/documents

# Cache directory for processed data
CACHE_PATH=backend/agents/rag/data/cache

# ============= PubMed Configuration =============
# Email (required for high-volume PubMed queries)
PUBMED_EMAIL=your-email@example.com

# Max PubMed results per query
PUBMED_MAX_RESULTS=100

# ============= Retrieval Configuration =============
# Top K documents to retrieve
TOP_K_RESULTS=5

# Minimum similarity score for retrieved documents (0.0 - 1.0)
SIMILARITY_THRESHOLD=0.6

# Maximum tokens from retrieval to include in context
MAX_RETRIEVED_TOKENS=4000

# Chunk size for document splitting (in characters)
CHUNK_SIZE=500

# Chunk overlap for context continuity
CHUNK_OVERLAP=100

# ============= Logging & Debug =============
# Debug mode (verbose logging)
DEBUG_MODE=false

# Log all retrievals to file
LOG_RETRIEVALS=true

# Log file location
LOG_FILE=backend/agents/rag/data/rag.log

# ============= API Configuration =============
# FastAPI server host
API_HOST=0.0.0.0

# FastAPI server port
API_PORT=8000

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
